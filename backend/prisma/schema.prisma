// This file is generated by Prisma CLI
// See: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  plan         String   @default("starter")
  email        String?
  phone        String?
  address      String?
  specialty    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users        User[]
  patients     Patient[]
  leads        Lead[]
  appointments Appointment[]
  prontuarios  Prontuario[]
  staff        Staff[]
  stockItems   StockItem[]
  payments     Payment[]
  templates    MessageTemplate[]
}

model User {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  email        String
  password     String
  role         String   @default("staff") // admin | dentist | staff | receptionist
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  movements    StockMovement[]

  @@unique([clinicId, email])
}

model Patient {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  cpf          String?
  dob          DateTime?
  phone        String?
  email        String?
  insurance    String   @default("Particular")
  status       String   @default("Ativo") // Ativo | Inativo | Em tratamento
  avatar       String?
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  prontuarios  Prontuario[]
  payments     Payment[]
}

model Lead {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  phone        String?
  email        String?
  interest     String?
  source       String   @default("Outros") // Instagram | Google | Indicação | Site | WhatsApp
  stage        String   @default("novo")   // novo | contato | consulta | ganho | perdido
  value        Float?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model Appointment {
  id           String   @id @default(cuid())
  clinicId     String
  patientId    String
  userId       String?
  procedure    String
  date         DateTime
  time         String
  status       String   @default("agendada") // agendada | confirmada | realizada | cancelada
  notes        String?
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient  @relation(fields: [patientId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])
}

model Prontuario {
  id             String   @id @default(cuid())
  clinicId       String
  patientId      String
  chiefComplaint String?
  diagnosis      String?
  treatment      String?
  prescription   String?
  observations   String?
  toothStates    Json?    // odontogram state object
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic         Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient        Patient  @relation(fields: [patientId], references: [id])
}

model Staff {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  role         String
  email        String?
  phone        String?
  salary       Float    @default(0)
  schedule     String?
  status       String   @default("Ativo") // Ativo | Inativo | Férias
  avatar       String?
  color        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}

model StockItem {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  category     String
  qty          Int      @default(0)
  minQty       Int      @default(5)
  cost         Float    @default(0)
  supplier     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  movements    StockMovement[]
}

model StockMovement {
  id           String    @id @default(cuid())
  stockItemId  String
  userId       String?
  type         String    // Entrada | Saída
  qty          Int
  createdAt    DateTime  @default(now())

  item         StockItem @relation(fields: [stockItemId], references: [id])
  user         User?     @relation(fields: [userId], references: [id])
}

model Payment {
  id           String   @id @default(cuid())
  clinicId     String
  patientId    String?
  procedure    String?
  value        Float
  method       String?  // Cartão | PIX | Boleto | Dinheiro | Parcelado
  status       String   @default("Pendente") // Pago | Pendente | Atrasado
  invoiceId    String?
  date         DateTime @default(now())
  createdAt    DateTime @default(now())

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient      Patient? @relation(fields: [patientId], references: [id])
}

model MessageTemplate {
  id           String   @id @default(cuid())
  clinicId     String
  name         String
  text         String
  createdAt    DateTime @default(now())

  clinic       Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
}
