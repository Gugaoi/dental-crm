# Database
DATABASE_URL="postgresql://crm_user:crm_pass@postgres:5432/dental_crm?schema=public"

# Redis
REDIS_URL="redis://redis:6379"

# JWT — CHANGE THIS IN PRODUCTION!
JWT_SECRET="super-secret-jwt-key-change-in-production"

# Webhook deploy secret — must match GitHub Secret WEBHOOK_SECRET
WEBHOOK_SECRET="super-secret-webhook-key-change-in-production"

# Path to app on KVM (for webhook deploy)
APP_DIR="/root/apps/dental-crm"

# API Port
PORT=3001

# Environment
NODE_ENV=production
